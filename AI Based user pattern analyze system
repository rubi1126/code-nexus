// Navigation
function navigate(sectionId) {
    document.querySelectorAll('.hidden-section, #section-home').forEach(el => {
        el.style.display = 'none';
    });
    
    document.querySelectorAll('nav button').forEach(btn => {
        btn.className = 'w-full text-left px-4 py-3 rounded-lg hover:bg-gray-800 text-gray-300 font-medium flex items-center gap-3 transition-colors';
    });
    
    document.getElementById(`section-${sectionId}`).style.display = 'block';
    const activeBtn = document.getElementById(`nav-${sectionId}`);
    if (activeBtn) {
        activeBtn.className = 'w-full text-left px-4 py-3 rounded-lg bg-primary/20 text-primary font-medium flex items-center gap-3 transition-colors';
    }
    
    const titles = {
        'home': 'Home',
        'dataset': 'Dataset Management',
        'dashboard': 'AI Analytics Dashboard',
        'simulator': 'What-If Simulator'
    };
    document.getElementById('page-title').innerText = titles[sectionId];

    if (sectionId === 'dashboard' && isModelTrained) {
        loadDashboardSummary();
    }
}

