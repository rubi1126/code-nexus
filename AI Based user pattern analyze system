// Check API Connection
async function checkApi() {
    try {
        const res = await fetch(`${API_BASE}/`);
        if (res.ok) {
            const statusBadge = document.getElementById('api-status');
            statusBadge.className = 'px-3 py-1 rounded-full text-xs font-medium bg-green-500/20 text-green-400 flex items-center gap-2';
            statusBadge.innerHTML = '<div class="w-2 h-2 rounded-full bg-green-500"></div> API Connected';
        }
    } catch (e) {
        console.warn("API not connected yet.");
    }
}

setInterval(checkApi, 5000);
